{
  "manifest_version": 3,
  "name": "TranscripTonic",
  "version": "3.3.5",
  "description": "Simple Google Meet transcripts. Private and open source.",
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "scripting",
    "declarativeNetRequestWithHostAccess",
    "alarms"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "optional_permissions": [
    "notifications"
  ],
  "optional_host_permissions": [
    "*://*/*",
    "https://*.zoom.us/",
    "https://teams.live.com/*",
    "https://teams.microsoft.com/*",
    "https://teams.cloud.microsoft/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["faqutwo-sink.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "transcriptonic-faqutwo@qutwo.internal",
      "update_url": "https://raw.githubusercontent.com/qutwo-internal/faqutwo-transcript-browser-extension/main/updates.json",
      "strict_min_version": "140.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": false,
        "path": "rules.json"
      }
    ]
  }
}